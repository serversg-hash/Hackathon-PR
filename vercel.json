{
  "version": 2,
  "builds": [
    {
      "src": "Backend/vercel-entry.ts",
      "use": "@vercel/node"
    },
    {
      "src": "Frontend/index.html",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "Frontend/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "Backend/vercel-entry.ts"
    },
    {
      "src": "/(.*)",
      "dest": "Frontend/index.html"
    }
  ]
}
